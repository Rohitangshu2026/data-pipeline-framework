<job id="parallel_pipeline">

    <stage id="extractA">
        <task>
            <input src="fileA"/>
            <action type="ReadCSV"/>
            <output src="datasetA"/>
        </task>
    </stage>

    <stage id="extractB">
        <task>
            <input src="fileB"/>
            <action type="ReadCSV"/>
            <output src="datasetB"/>
        </task>
    </stage>

    <stage id="merge" pre_req="extractA extractB">
        <task>
            <input src="datasetA"/>
            <action type="Merge"/>
            <output src="merged"/>
        </task>
    </stage>

</job>