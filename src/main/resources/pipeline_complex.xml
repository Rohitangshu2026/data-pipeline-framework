<?xml version="1.0" encoding="UTF-8"?>

<job id="enterprise_data_pipeline">

    <!-- ================= STAGE 1 ================= -->
    <stage id="extract_users">

        <on_error handling_strategy="retry" retry_count="3"/>

        <task>
            <input src="users_db"/>
            <action type="read"/>
            <output src="users_raw"/>
        </task>

        <task>
            <input src="users_raw"/>
            <action type="validate"/>
            <output src="users_validated"/>
        </task>

    </stage>


    <stage id="extract_orders">

        <on_error handling_strategy="retry" retry_count="2"/>

        <task>
            <input src="orders_db"/>
            <action type="read"/>
            <output src="orders_raw"/>
        </task>

        <task>
            <input src="orders_raw"/>
            <action type="validate"/>
            <output src="orders_validated"/>
        </task>

    </stage>


    <stage id="extract_products">

        <task>
            <input src="products_db"/>
            <action type="read"/>
            <output src="products_raw"/>
        </task>

    </stage>


    <!-- ================= STAGE 2 ================= -->

    <stage id="clean_users" pre_req="extract_users">

        <on_error handling_strategy="retry" retry_count="1"/>

        <task>
            <input src="users_validated"/>
            <action type="clean"/>
            <output src="users_clean"/>
        </task>

    </stage>


    <stage id="clean_orders" pre_req="extract_orders">

        <task>
            <input src="orders_validated"/>
            <action type="clean"/>
            <output src="orders_clean"/>
        </task>

    </stage>


    <stage id="clean_products" pre_req="extract_products">

        <task>
            <input src="products_raw"/>
            <action type="clean"/>
            <output src="products_clean"/>
        </task>

    </stage>


    <!-- ================= STAGE 3 ================= -->

    <stage id="join_user_orders" pre_req="clean_users clean_orders">

        <on_error handling_strategy="abort"/>

        <task>
            <input src="users_clean"/>
            <action type="join_orders"/>
            <output src="user_orders_joined"/>
        </task>

    </stage>


    <stage id="enrich_products" pre_req="clean_products">

        <task>
            <input src="products_clean"/>
            <action type="enrich"/>
            <output src="products_enriched"/>
        </task>

    </stage>


    <!-- ================= STAGE 4 ================= -->

    <stage id="analytics_prepare" pre_req="join_user_orders enrich_products">

        <task>
            <input src="user_orders_joined"/>
            <action type="aggregate"/>
            <output src="sales_metrics"/>
        </task>

        <task>
            <input src="products_enriched"/>
            <action type="aggregate"/>
            <output src="product_metrics"/>
        </task>

    </stage>


    <!-- ================= STAGE 5 ================= -->

    <stage id="generate_reports" pre_req="analytics_prepare">

        <task>
            <input src="sales_metrics"/>
            <action type="generate_report"/>
            <output src="sales_report"/>
        </task>

        <task>
            <input src="product_metrics"/>
            <action type="generate_report"/>
            <output src="product_report"/>
        </task>

    </stage>


    <!-- ================= STAGE 6 ================= -->

    <stage id="publish_reports" pre_req="generate_reports">

        <on_error handling_strategy="retry" retry_count="2"/>

        <task>
            <input src="sales_report"/>
            <action type="upload"/>
            <output src="sales_report_published"/>
        </task>

        <task>
            <input src="product_report"/>
            <action type="upload"/>
            <output src="product_report_published"/>
        </task>

    </stage>


    <!-- ================= FINAL STAGE ================= -->

    <stage id="pipeline_complete" pre_req="publish_reports">

        <task>
            <input src="sales_report_published"/>
            <action type="notify"/>
            <output src="notification_sent"/>
        </task>

    </stage>

</job>