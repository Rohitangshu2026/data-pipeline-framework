<job id="simple_pipeline">

    <stage id="extract">
        <task>
            <input src="input_csv"/>
            <action type="ReadCSV"/>
            <output src="raw_data"/>
        </task>
    </stage>

    <stage id="transform" pre_req="extract">
        <task>
            <input src="raw_data"/>
            <action type="Transform"/>
            <output src="clean_data"/>
        </task>
    </stage>

    <stage id="load" pre_req="transform">
        <task>
            <input src="clean_data"/>
            <action type="WriteCSV"/>
            <output src="output_csv"/>
        </task>
    </stage>

</job>