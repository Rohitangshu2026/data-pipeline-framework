<job id="filter-heavy-pipeline">

    <!-- ================= STAGE 1 ================= -->
    <!-- Filter high salary -->
    <stage id="high_salary">
        <task>
            <input>
                <csv src="src/main/resources/employees.csv"/>
            </input>

            <action type="transform">
                <method name="filter">
                    <param name="column" value="salary"/>
                    <param name="operator" value=">"/>
                    <param name="value" value="60000"/>
                </method>
            </action>

            <output>
                <csv src="src/main/resources/output/high_salary.csv"/>
            </output>
        </task>
    </stage>


    <!-- ================= STAGE 2 ================= -->
    <!-- Filter mid salary -->
    <stage id="mid_salary">
        <task>
            <input>
                <csv src="src/main/resources/employees.csv"/>
            </input>

            <action type="transform">
                <method name="filter">
                    <param name="column" value="salary"/>
                    <param name="operator" value=">"/>
                    <param name="value" value="50000"/>
                </method>
            </action>

            <output>
                <csv src="src/main/resources/output/mid_salary.csv"/>
            </output>
        </task>
    </stage>


    <!-- ================= STAGE 3 ================= -->
    <!-- Seniors from high salary -->
    <stage id="senior_high" pre_req="high_salary">
        <task>
            <input>
                <csv src="src/main/resources/output/high_salary.csv"/>
            </input>

            <action type="transform">
                <method name="filter">
                    <param name="column" value="age"/>
                    <param name="operator" value=">"/>
                    <param name="value" value="35"/>
                </method>
            </action>

            <output>
                <csv src="src/main/resources/output/senior_high.csv"/>
            </output>
        </task>
    </stage>


    <!-- ================= STAGE 4 ================= -->
    <!-- Seniors from mid salary -->
    <stage id="senior_mid" pre_req="mid_salary">
        <task>
            <input>
                <csv src="src/main/resources/output/mid_salary.csv"/>
            </input>

            <action type="transform">
                <method name="filter">
                    <param name="column" value="age"/>
                    <param name="operator" value=">"/>
                    <param name="value" value="30"/>
                </method>
            </action>

            <output>
                <csv src="src/main/resources/output/senior_mid.csv"/>
            </output>
        </task>
    </stage>


    <!-- ================= STAGE 5 ================= -->
    <!-- Finance department from high salary -->
    <stage id="finance_high" pre_req="high_salary">
        <task>
            <input>
                <csv src="src/main/resources/output/high_salary.csv"/>
            </input>

            <action type="transform">
                <method name="filter">
                    <param name="column" value="dept_id"/>
                    <param name="operator" value="="/>
                    <param name="value" value="102"/>
                </method>
            </action>

            <output>
                <csv src="src/main/resources/output/finance_high.csv"/>
            </output>
        </task>
    </stage>


    <!-- ================= STAGE 6 ================= -->
    <!-- Engineering department from mid salary -->
    <stage id="engineering_mid" pre_req="mid_salary">
        <task>
            <input>
                <csv src="src/main/resources/output/mid_salary.csv"/>
            </input>

            <action type="transform">
                <method name="filter">
                    <param name="column" value="dept_id"/>
                    <param name="operator" value="="/>
                    <param name="value" value="101"/>
                </method>
            </action>

            <output>
                <csv src="src/main/resources/output/engineering_mid.csv"/>
            </output>
        </task>
    </stage>


    <!-- ================= STAGE 7 ================= -->
    <!-- Very high salary -->
    <stage id="very_high_salary" pre_req="high_salary">
        <task>
            <input>
                <csv src="src/main/resources/output/high_salary.csv"/>
            </input>

            <action type="transform">
                <method name="filter">
                    <param name="column" value="salary"/>
                    <param name="operator" value=">"/>
                    <param name="value" value="80000"/>
                </method>
            </action>

            <output>
                <csv src="src/main/resources/output/very_high_salary.csv"/>
            </output>
        </task>
    </stage>


    <!-- ================= STAGE 8 ================= -->
    <!-- Final refinement -->
    <stage id="final_output" pre_req="senior_high very_high_salary">
        <task>
            <input>
                <csv src="src/main/resources/output/very_high_salary.csv"/>
            </input>

            <action type="transform">
                <method name="filter">
                    <param name="column" value="age"/>
                    <param name="operator" value=">"/>
                    <param name="value" value="40"/>
                </method>
            </action>

            <output>
                <csv src="src/main/resources/output/final_output.csv"/>
            </output>
        </task>
    </stage>

</job>